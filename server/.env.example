DATABASE_URL=postgresql://user:password@localhost:5432/pokertitan
# Required: at least 32 characters of high-entropy randomness.
# Generate with:  openssl rand -base64 48
JWT_SECRET=your-secret-key-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL where Google should redirect after consent.
# In prod: https://pokertitan.pro/auth/google/callback
OAUTH_CALLBACK_URL=
# In prod set NODE_ENV=production so cookies are flagged Secure.
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
